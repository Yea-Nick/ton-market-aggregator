POSTGRES_DB=ton_prices
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

PORT=4000
NODE_ENV=production
POSTGRES_SSL=false
POSTGRES_LOGGING=false
DB_SYNCHRONIZE=false

KAFKA_GROUP_ID=prices-service-consumer
KAFKA_FROM_BEGINNING=false
KAFKA_SSL=false
KAFKA_ALLOW_AUTO_TOPIC_CREATION=false

KAFKA_TOPIC=ton.prices.raw
KAFKA_RETENTION_MS=21600000
KAFKA_RETENTION_BYTES=1073741824

KAFKA_HEALTH_TOPIC=ton.sources.health
KAFKA_HEALTH_RETENTION_MS=2592000000
KAFKA_HEALTH_RETENTION_BYTES=268435456

WS_PATH=/ws/prices
WS_HEARTBEAT_MS=30000

LOG_LEVEL=info
POLL_INTERVAL_MS=5000
SYMBOL=TONUSDT
ENABLED_EXCHANGES=bybit,bitget,stonfi,dedust

NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_SYMBOL=TONUSDT

REQUEST_TIMEOUT_MS=2500
MAX_RETRIES=2
RETRY_BASE_BACKOFF_MS=250
RETRY_MAX_BACKOFF_MS=1500

BREAKER_FAILURE_THRESHOLD=5
BREAKER_OPEN_MS=60000
BREAKER_OPEN_MS_403=600000

STALE_AFTER_CONSECUTIVE=3
STALE_HEALTH_COOLDOWN_MS=60000
DUPLICATE_HEALTH_COOLDOWN_MS=60000

BYBIT_BASE_URL=https://api.bybit.com
BITGET_BASE_URL=https://api.bitget.com
STONFI_BASE_URL=https://api.ston.fi
TONCENTER_API_URL=https://mainnet-v4.tonhubapi.com